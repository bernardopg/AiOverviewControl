      ;;
    amp)
      json_note_usage amp amp-local "Amp account" "subscription" "No public quota API; usage is available in Amp settings" "ampcode.com"
      ;;
    cline)
      json_note_usage cline cline-local "Cline account" "subscription" "No public quota API; usage is available in the Cline client" "app.cline.bot"
      ;;
    opencode)
      json_note_usage opencode opencode-local "OpenCode" "proxy" "OpenCode routes to underlying providers directly — check each provider's card" "opencode.ai"
      ;;
    together)
      fetch_together_native
      ;;
    groq)
      fetch_groq_native
      ;;
    cohere)
      fetch_cohere_native
      ;;
    replicate)
      fetch_replicate_native
      ;;
    fireworks)
      fetch_fireworks_native
      ;;
    ai21)
      fetch_ai21_native
      ;;
    *)
      json_error "$provider" provider-backend 1 provider "No local provider adapter is registered for $provider."
      ;;
  esac
}

IFS=',' read -r -a providers <<< "$PROVIDERS_CSV"
normalized_providers=()
result_files=()
pids=()

for raw_provider in "${providers[@]}"; do
  provider="$(printf '%s' "$raw_provider" | xargs | tr '[:upper:]' '[:lower:]')"
  [ -n "$provider" ] || continue
  normalized_providers+=("$provider")
  result_file="$(mktemp)"
  result_files+=("$result_file")
  (
    item="$(fetch_provider "$provider")"
    if ! printf '%s' "$item" | jq -e . >/dev/null 2>&1; then
      item="$(json_error "$provider" provider-backend 1 runtime "Provider backend returned invalid JSON.")"
    fi
    printf '%s' "$item" > "$result_file"
  ) &
  pids+=("$!")
done

for pid in "${pids[@]}"; do
  wait "$pid" || true
done

# Append one usage snapshot per healthy provider so the widget can render
# trend arrows and history sparklines. Best-effort: never block the response.
record_history() {
  local history_dir="${XDG_CACHE_HOME:-$HOME/.cache}/AiOverviewControl"
  local history_file="$history_dir/usage-history.jsonl"
  mkdir -p "$history_dir" 2>/dev/null || return 0
  # Retention: AIOC_HISTORY_MAX snapshots kept after trim (default 2000); the
  # trim itself only kicks in past 2x that to avoid rewriting on every run.
  local max_lines="${AIOC_HISTORY_MAX:-2000}"
  case "$max_lines" in ''|*[!0-9]*) max_lines=2000 ;; esac
  [ "$max_lines" -ge 50 ] || max_lines=50

  local now idx file line
  now="$(date +%s)"
  for idx in "${!normalized_providers[@]}"; do
    file="${result_files[$idx]}"
    [ -s "$file" ] || continue
    # Only snapshot providers that report a real, non-zero quota/spend
    # percentage. Balance, analytics (e.g. Cloudflare neurons), and
    # informational cards all carry usedPercent:0 — recording those produced
    # flat-zero sparklines that polluted history and meant nothing. A genuine
    # 0% quota reading adds no trend signal either, so the line simply starts
    # at the first measurable datapoint.
    line="$(jq -c --argjson ts "$now" \
      'select((.usage.primary.usedPercent // 0) > 0) | {ts:$ts, provider:.provider, pct:(.usage.primary.usedPercent)}' \
      "$file" 2>/dev/null || true)"
    [ -n "$line" ] && printf '%s\n' "$line" >> "$history_file"
  done
  if [ -f "$history_file" ] && [ "$(wc -l < "$history_file")" -gt "$((max_lines * 2))" ]; then
    tail -n "$max_lines" "$history_file" > "$history_file.tmp" && mv -f "$history_file.tmp" "$history_file"
  fi
  return 0
}
record_history

printf '['
for index in "${!normalized_providers[@]}"; do
  [ "$index" -eq 0 ] || printf ','
  if [ -s "${result_files[$index]}" ]; then
    cat "${result_files[$index]}"
  else
    json_error "${normalized_providers[$index]}" provider-backend 1 runtime "Provider backend produced no output."
  fi
done
printf ']'
