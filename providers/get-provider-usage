      fetch_mistral_native
      ;;
    ollama)
      fetch_ollama_native
      ;;
    nvidia|nim)
      fetch_nvidia_native
      ;;
    cloudflare)
      fetch_cloudflare_native
      ;;
    vertexai|vertex)
      fetch_vertexai_native
      ;;
    byteplus|ark|modelark)
      fetch_byteplus_native
      ;;
    qwen|dashscope|alibaba)
      fetch_qwen_native
      ;;
    perplexity)
      try_codexbar perplexity || json_note_usage perplexity perplexity-web "Perplexity account" "subscription" "Usage at perplexity.ai/settings/billing" "perplexity.ai"
      ;;
    cursor)
      try_codexbar cursor || json_note_usage cursor cursor-local "Cursor account" "subscription" "Usage at cursor.com/settings" "cursor.com"
      ;;
    kilo)
      try_codexbar kilo || json_note_usage kilo kilo-local "Kilo account" "subscription" "Usage at kilo.ai" "kilo.ai"
      ;;
    kiro)
      try_codexbar kiro || json_note_usage kiro kiro-local "Kiro account" "subscription" "Usage at kiro.ai" "kiro.ai"
      ;;
    warp)
      try_codexbar warp || json_note_usage warp warp-local "Warp account" "subscription" "Usage at app.warp.dev" "app.warp.dev"
      ;;
    amp)
      try_codexbar amp || json_note_usage amp amp-local "Amp account" "subscription" "Usage at ampcode.com" "ampcode.com"
      ;;
    cline)
      try_codexbar cline || json_note_usage cline cline-local "Cline account" "subscription" "Usage visible in VS Code Cline panel — no REST endpoint" "app.cline.bot"
      ;;
    opencode)
      json_note_usage opencode opencode-local "OpenCode" "proxy" "OpenCode routes to underlying providers directly — check each provider's card" "opencode.ai"
      ;;
    together)
      fetch_together_native
      ;;
    groq)
      fetch_groq_native
      ;;
    cohere)
      fetch_cohere_native
      ;;
    replicate)
      fetch_replicate_native
      ;;
    fireworks)
      fetch_fireworks_native
      ;;
    ai21)
      fetch_ai21_native
      ;;
    *)
      try_codexbar "$provider" || json_error "$provider" codexbar 1 provider "No local provider adapter is available for $provider."
      ;;
  esac
}

