#!/usr/bin/env bash
set -uo pipefail

CODEXBAR_BIN="${1:-}"
PROVIDERS_CSV="${2:-codex,claude,copilot}"
SOURCE_MODE="${3:-cli}"
COPILOT_SCRIPT="${4:-}"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
[ -n "$COPILOT_SCRIPT" ] || COPILOT_SCRIPT="$SCRIPT_DIR/get-copilot-usage"
CLAUDE_SCRIPT="$SCRIPT_DIR/get-claude-usage"

json_error() {
  local provider="$1"
  local source="$2"
  local code="$3"
  local kind="$4"
  local message="$5"
  case "$code" in
    ""|*[!0-9]*) code=1 ;;
  esac
  code="$((10#$code))"
  [ "$code" -gt 0 ] 2>/dev/null || code=1
  jq -cn \
    --arg provider "$provider" \
    --arg source "$source" \
    --arg kind "$kind" \
    --arg message "$message" \
    --argjson code "${code:-1}" \
    '{provider:$provider,source:$source,error:{code:$code,kind:$kind,message:$message}}'
}

json_note_usage() {
  local provider="$1"
  local source="$2"
  local account="$3"
  local login="$4"
  local label="$5"
  local credits="${6:-unknown}"
  jq -cn \
    --arg provider "$provider" \
    --arg source "$source" \
    --arg account "$account" \
    --arg login "$login" \
    --arg label "$label" \
    --arg credits "$credits" \
    '{
      provider:$provider,
      source:$source,
      usage:{
        identity:{providerID:$provider,accountEmail:$account,loginMethod:$login},
        accountEmail:$account,
        loginMethod:$login,
        primary:{usedPercent:0,windowMinutes:null,resetsAt:null,resetDescription:$label},
        secondary:null,
        tertiary:null,
        updatedAt:(now|todateiso8601)
      },
      credits:{remaining:$credits}
    }'
}

find_codexbar() {
  if [ -n "$CODEXBAR_BIN" ] && [ -x "$CODEXBAR_BIN" ]; then
    printf '%s\n' "$CODEXBAR_BIN"
    return 0
  fi
  command -v codexbar 2>/dev/null && return 0
  [ -x "$HOME/.local/bin/codexbar" ] && printf '%s\n' "$HOME/.local/bin/codexbar" && return 0
  [ -x /usr/local/bin/codexbar ] && printf '%s\n' /usr/local/bin/codexbar && return 0
  return 1
}

pick_codexbar_item() {
  local provider="$1"
  jq -c --arg provider "$provider" '
    ([if type == "array" then .[] else . end]
      | map(if (.provider // "") == "" then . + {provider:$provider} else . end)) as $items
    | (($items[] | select(.provider == $provider)) // $items[0] // {provider:$provider})
  '
}

source_candidates() {
  local provider="$1"
  case "$provider" in
    codex)
      printf '%s\n' cli auto api oauth web | awk 'NF && !seen[$0]++'
      ;;
    gemini)
      if [ -n "$SOURCE_MODE" ] && [ "$SOURCE_MODE" != "auto" ]; then
        printf '%s\n' "$SOURCE_MODE" auto oauth api web | awk 'NF && !seen[$0]++'
      else
        printf '%s\n' auto oauth api web | awk 'NF && !seen[$0]++'
      fi
      ;;
    openrouter|9router)
      printf '%s\n' api auto cli oauth web | awk 'NF && !seen[$0]++'
      ;;
    *)
      if [ -n "$SOURCE_MODE" ] && [ "$SOURCE_MODE" != "auto" ]; then
        printf '%s\n' "$SOURCE_MODE"
      else
        printf '%s\n' cli auto oauth api web | awk 'NF && !seen[$0]++'
      fi
      ;;
  esac
}

try_codexbar() {
  local provider="$1"
  local bin
  if ! bin="$(find_codexbar)"; then
    return 127
  fi

  local source tmp_out tmp_err status picked
  tmp_out="$(mktemp)"
  tmp_err="$(mktemp)"

  while IFS= read -r source; do
    [ -n "$source" ] || continue
    : > "$tmp_out"
    : > "$tmp_err"

    timeout --kill-after=5s 40s "$bin" usage --format json --provider "$provider" --source "$source" >"$tmp_out" 2>"$tmp_err"
    status=$?

    if [ -s "$tmp_out" ] && jq -e . "$tmp_out" >/dev/null 2>&1; then
      picked="$(pick_codexbar_item "$provider" < "$tmp_out" 2>/dev/null || true)"
      if [ -n "$picked" ] && printf '%s' "$picked" | jq -e 'has("error") | not' >/dev/null 2>&1; then
        printf '%s\n' "$picked"
        rm -f "$tmp_out" "$tmp_err"
        return 0
      fi
    fi

    [ "$status" -eq 0 ] && break
  done < <(source_candidates "$provider")

  local message
  message="$(cat "$tmp_err" 2>/dev/null || true)"
  if [ -z "$message" ] && [ -s "$tmp_out" ]; then
    message="$(jq -r --arg provider "$provider" '
      ([if type == "array" then .[] else . end]
       | map(select((.provider // $provider) == $provider))
       | .[0].error.message) // empty
    ' "$tmp_out" 2>/dev/null || true)"
  fi
  [ -n "$message" ] || message="codexbar has no working strategy for $provider."

  rm -f "$tmp_out" "$tmp_err"
  return 1
}

fetch_copilot() {
  if [ -x "$COPILOT_SCRIPT" ]; then
    local tmp_out tmp_err status message
    tmp_out="$(mktemp)"
    tmp_err="$(mktemp)"
    "$COPILOT_SCRIPT" >"$tmp_out" 2>"$tmp_err"
    status=$?

    if [ -s "$tmp_out" ] && jq -e . "$tmp_out" >/dev/null 2>&1; then
      cat "$tmp_out"
      rm -f "$tmp_out" "$tmp_err"
      return 0
    fi

    message="$(cat "$tmp_err" 2>/dev/null || true)"
    [ -n "$message" ] || message="GitHub Copilot usage helper returned invalid output."
    rm -f "$tmp_out" "$tmp_err"

    if [ "$status" -ne 0 ]; then
      try_codexbar copilot || json_error copilot github-copilot-api "$status" runtime "$message"
      return 0
    fi

    json_error copilot github-copilot-api 1 runtime "$message"
    return 0
  fi
  try_codexbar copilot || json_error copilot github-copilot-api 127 runtime "Copilot helper script is missing or not executable."
}

fetch_claude_native() {
  if [ ! -f "$CLAUDE_SCRIPT" ]; then
    json_error claude claude-local 127 runtime "Local Claude usage helper is missing."
    return 0
  fi

  local tmp_out tmp_err status
  tmp_out="$(mktemp)"
  tmp_err="$(mktemp)"
  bash "$CLAUDE_SCRIPT" >"$tmp_out" 2>"$tmp_err"
  status=$?

  if [ "$status" -ne 0 ]; then
    local message
    message="$(cat "$tmp_err" 2>/dev/null || true)"
    [ -n "$message" ] || message="Claude local usage helper exited with status $status."
    rm -f "$tmp_out" "$tmp_err"
    json_error claude claude-local "$status" runtime "$message"
    return 0
  fi

  jq -Rn '
    def num($k): ((.[$k] // 0) | tonumber? // 0);
    def text($k): (.[$k] // "");
    def nullable($v): if ($v == null or $v == "") then null else $v end;
    def clamp($n): if $n < 0 then 0 elif $n > 100 then 100 else $n end;
    reduce inputs as $line ({};
      ($line | capture("^(?<key>[^=]+)=(?<value>.*)$")?) as $kv
      | if $kv then .[$kv.key] = $kv.value else . end
    )
    | . as $d
    | {
      provider:"claude",
      source:"claude-local",
      usage:{
        identity:{
          providerID:"claude",
          accountEmail:"Claude Code",
          loginMethod:($d.SUBSCRIPTION_TYPE // "unknown")
        },
        accountEmail:"Claude Code",
        loginMethod:($d.SUBSCRIPTION_TYPE // "unknown"),
        primary:{
          usedPercent:clamp(($d.FIVE_HOUR_UTIL // 0 | tonumber? // 0)),
          windowMinutes:300,
          resetsAt:nullable($d.FIVE_HOUR_RESET),
          resetDescription:"5 hour"
        },
        secondary:{
          usedPercent:clamp(($d.SEVEN_DAY_UTIL // 0 | tonumber? // 0)),
          windowMinutes:10080,
          resetsAt:nullable($d.SEVEN_DAY_RESET),
          resetDescription:"7 day"
        },
        tertiary:null,
        updatedAt:(now|todateiso8601)
      },
      credits:{remaining:($d.RATE_LIMIT_TIER // "unknown")}
    }
  ' < "$tmp_out"
  rm -f "$tmp_out" "$tmp_err"
}

fetch_gemini_native() {
  local key="${GEMINI_API_KEY:-${GOOGLE_API_KEY:-${GOOGLE_GENERATIVE_AI_API_KEY:-}}}"
  if [ -n "$key" ]; then
    local tmp_body http_status
    tmp_body="$(mktemp)"
    http_status="$(curl -sS --max-time 8 -o "$tmp_body" -w '%{http_code}' \
      "https://generativelanguage.googleapis.com/v1beta/models?key=${key}" 2>/dev/null || true)"
    if [ "$http_status" = "200" ]; then
      rm -f "$tmp_body"
      json_note_usage gemini gemini-api-key "Gemini API key" "api-key" "Quota visible in AI Studio" "AI Studio"
      return 0
    fi

    local message
    message="$(jq -r '.error.message // empty' "$tmp_body" 2>/dev/null || true)"
    [ -n "$message" ] || message="Gemini API key check returned HTTP ${http_status:-0}."
    rm -f "$tmp_body"
    json_error gemini gemini-api-key "${http_status:-1}" provider "$message"
    return 0
  fi

  local creds="$HOME/.gemini/oauth_creds.json"
  if [ -f "$creds" ] && jq -e '.access_token or .refresh_token' "$creds" >/dev/null 2>&1; then
    local account
    account="$(jq -r '.active // "Gemini CLI"' "$HOME/.gemini/google_accounts.json" 2>/dev/null || printf 'Gemini CLI')"
    [ -n "$account" ] && [ "$account" != "null" ] || account="Gemini CLI"
    json_note_usage gemini gemini-cli "$account" "oauth" "Gemini CLI authenticated" "AI Studio"
    return 0
  fi

  json_error gemini gemini-local 2 provider "Gemini is not authenticated locally. Run gemini once, or set GEMINI_API_KEY/GOOGLE_API_KEY."
}

fetch_openrouter_native() {
  local key="${OPENROUTER_API_KEY:-}"
  if [ -z "$key" ]; then
    json_error openrouter openrouter-api 2 provider "OPENROUTER_API_KEY is not set, and codexbar has no OpenRouter strategy here."
    return 0
  fi

  local tmp_body http_status
  tmp_body="$(mktemp)"
  http_status="$(curl -sS --max-time 8 -o "$tmp_body" -w '%{http_code}' \
    -H "Authorization: Bearer ${key}" \
    -H "Accept: application/json" \
    "https://openrouter.ai/api/v1/auth/key" 2>/dev/null || true)"

  if [ "$http_status" != "200" ]; then
    local message
    message="$(jq -r '.error.message // .message // empty' "$tmp_body" 2>/dev/null || true)"
    [ -n "$message" ] || message="OpenRouter key check returned HTTP ${http_status:-0}."
    rm -f "$tmp_body"
    json_error openrouter openrouter-api "${http_status:-1}" provider "$message"
    return 0
  fi

  jq -c '
    def pct($used; $limit):
      if (($limit // 0) | tonumber) > 0 then
        ((($used // 0) | tonumber) / (($limit // 0) | tonumber) * 100)
        | if . < 0 then 0 elif . > 100 then 100 else . end
      else 0 end;
    .data as $d
    | ($d.label // $d.name // "OpenRouter API key") as $label
    | ($d.limit // null) as $limit
    | {
      provider:"openrouter",
      source:"openrouter-api",
      usage:{
        identity:{
          providerID:"openrouter",
          accountEmail:$label,
          loginMethod:(if ($d.is_free_tier // false) then "free-tier" else "api-key" end)
        },
        accountEmail:$label,
        loginMethod:(if ($d.is_free_tier // false) then "free-tier" else "api-key" end),
        primary:{
          usedPercent:pct($d.usage; $limit),
          windowMinutes:null,
          resetsAt:null,
          resetDescription:"Key limit"
        },
        secondary:{
          usedPercent:pct($d.usage_daily; $limit),
          windowMinutes:1440,
          resetsAt:null,
          resetDescription:"Daily"
        },
        tertiary:{
          usedPercent:pct($d.usage_monthly; $limit),
          windowMinutes:43200,
          resetsAt:null,
          resetDescription:"Monthly"
        },
        updatedAt:(now|todateiso8601)
      },
      credits:{
        remaining:(
          if ($d.limit_remaining != null) then ($d.limit_remaining | tostring)
          elif $limit == null then "unlimited"
          else "unknown"
          end
        )
      }
    }
  ' "$tmp_body"
  rm -f "$tmp_body"
}

fetch_9router_native() {
  local output_provider="${1:-9router}"
  local target_provider="${2:-$output_provider}"
  local soft_fail="${3:-false}"
  local source_label="9router-local"
  local db_path="$HOME/.9router/db/data.sqlite"
  local usage_json="$HOME/.9router/usage.json"
  local tmp_rows
  tmp_rows="$(mktemp)"

  if command -v sqlite3 >/dev/null 2>&1 && [ -f "$db_path" ]; then
    sqlite3 -json "$db_path" 'select dateKey as date, data from usageDaily order by dateKey' >"$tmp_rows" 2>/dev/null || true
  fi

  if [ ! -s "$tmp_rows" ] && [ -f "$usage_json" ]; then
    jq -c '[.dailySummary // {} | to_entries[] | {date:.key,data:(.value|tojson)}]' "$usage_json" >"$tmp_rows" 2>/dev/null || true
  fi

  if [ ! -s "$tmp_rows" ]; then
    rm -f "$tmp_rows"
    if [ "$soft_fail" = "soft" ]; then
      return 1
    fi
    json_error "$output_provider" "$source_label" 2 provider "9router usage database not found. Start 9router once so ~/.9router/db/data.sqlite or ~/.9router/usage.json exists."
    return 0
  fi

  local item
  item="$(jq -c \
    --arg output "$output_provider" \
    --arg target "$target_provider" \
    --arg source "$source_label" '
    def num($v): ($v // 0 | tonumber? // 0);
    def money($v):
      "$" + (((num($v) * 100 | round) / 100) | tostring);
    def compact($v):
      (num($v)) as $n
      | if $n >= 1000000000 then (((($n / 100000000) | round) / 10) | tostring) + "B"
        elif $n >= 1000000 then (((($n / 100000) | round) / 10) | tostring) + "M"
        elif $n >= 1000 then (((($n / 100) | round) / 10) | tostring) + "K"
        else (($n | round) | tostring)
        end;
    def pct($value; $max):
      if (num($max) > 0) then
        ((num($value) / num($max)) * 100)
        | if . < 0 then 0 elif . > 100 then 100 else . end
      else 0 end;
    def request_text($v): (num($v) | floor | tostring) + " req";
    def provider_data($day; $provider):
      if $provider == "9router" then $day
      else ($day.byProvider[$provider] // null)
      end;
    [ .[] | {date, day:(.data | if type == "string" then fromjson else . end)} ] as $days
    | [ $days[] | {date, data:provider_data(.day; $target)} | select(.data != null) ] as $matches
    | if ($matches | length) == 0 then empty
      else
        ($matches | sort_by(.date) | last) as $latest
        | (reduce $matches[] as $entry ({requests:0,promptTokens:0,completionTokens:0,cost:0};
            .requests += num($entry.data.requests)
            | .promptTokens += num($entry.data.promptTokens)
            | .completionTokens += num($entry.data.completionTokens)
            | .cost += num($entry.data.cost)
          )) as $total
        | ([$matches[].data.requests] | map(num(.)) | max // 0) as $maxRequests
        | ($matches | length) as $dayCount
        | (if $output == "9router" then "9router · all routed models" else ($output + " via 9router") end) as $account
        | {
            provider:$output,
            source:$source,
            usage:{
              identity:{providerID:$output,accountEmail:$account,loginMethod:"local-db"},
              accountEmail:$account,
              loginMethod:"local-db",
              primary:{
                usedPercent:pct($latest.data.requests; $maxRequests),
                windowMinutes:null,
                resetsAt:null,
                resetDescription:("Latest day " + $latest.date),
                displayValue:(money($latest.data.cost) + " · " + request_text($latest.data.requests))
              },
              secondary:{
                usedPercent:pct($total.requests; ($maxRequests * $dayCount)),
                windowMinutes:null,
                resetsAt:null,
                resetDescription:"Tracked total",
                displayValue:(money($total.cost) + " · " + request_text($total.requests))
              },
              tertiary:{
                usedPercent:0,
                windowMinutes:null,
                resetsAt:null,
                resetDescription:"Tokens",
                displayValue:(compact($total.promptTokens) + " in · " + compact($total.completionTokens) + " out")
              },
              updatedAt:(now|todateiso8601)
            },
            credits:{remaining:(money($total.cost) + " total")}
          }
      end
  ' "$tmp_rows" 2>/dev/null || true)"

  rm -f "$tmp_rows"

  if [ -z "$item" ]; then
    if [ "$soft_fail" = "soft" ]; then
      return 1
    fi
    json_error "$output_provider" "$source_label" 2 provider "9router has no recorded usage for ${target_provider}."
    return 0
  fi

  printf '%s\n' "$item"
}

fetch_deepseek_native() {
  local key="${DEEPSEEK_API_KEY:-}"
  if [ -z "$key" ]; then
    json_error deepseek deepseek-api 2 provider "DEEPSEEK_API_KEY is not set."
    return 0
  fi
  local tmp_body http_status
  tmp_body="$(mktemp)"
  http_status="$(curl -sS --max-time 8 -o "$tmp_body" -w '%{http_code}' \
    -H "Authorization: Bearer ${key}" \
    "https://api.deepseek.com/user/balance" 2>/dev/null || true)"
  if [ "$http_status" != "200" ]; then
    local message
    message="$(jq -r '.error.message // .message // empty' "$tmp_body" 2>/dev/null || true)"
    [ -n "$message" ] || message="DeepSeek balance API returned HTTP ${http_status:-0}."
    rm -f "$tmp_body"
    json_error deepseek deepseek-api "${http_status:-1}" provider "$message"
    return 0
  fi
  jq -c '
    def num($v): ($v // 0 | tonumber? // 0);
    def pct($used; $total):
      if num($total) > 0 then ((num($used) / num($total)) * 100) | if . < 0 then 0 elif . > 100 then 100 else . end
      else 0 end;
    (.balance_infos // []) as $infos
    | ($infos[0] // {}) as $b
    | num($b.total_balance) as $total
    | num($b.topped_up_balance) as $topped
    | num($b.granted_balance) as $granted
    | (num($b.total_balance) - num($b.topped_up_balance)) as $used
    | {
        provider: "deepseek",
        source: "deepseek-api",
        usage: {
          identity: { providerID: "deepseek", accountEmail: "DeepSeek account", loginMethod: "api-key" },
          accountEmail: "DeepSeek account",
          loginMethod: "api-key",
          primary: {
            usedPercent: pct($used; $total),
            windowMinutes: null,
            resetsAt: null,
            resetDescription: "Balance",
            displayValue: (($b.currency // "CNY") + " " + ($b.total_balance // "0"))
          },
          secondary: {
            usedPercent: 0,
            windowMinutes: null,
            resetsAt: null,
            resetDescription: "Granted credits",
            displayValue: (($b.currency // "CNY") + " " + ($b.granted_balance // "0"))
          },
          tertiary: null,
          updatedAt: (now | todateiso8601)
        },
        credits: {
          remaining: (($b.currency // "CNY") + " " + ($b.total_balance // "0"))
        }
      }
  ' "$tmp_body"
  rm -f "$tmp_body"
}

fetch_kimi_native() {
  local key="${MOONSHOT_API_KEY:-${KIMI_API_KEY:-}}"
  if [ -z "$key" ]; then
    json_error kimi kimi-api 2 provider "MOONSHOT_API_KEY or KIMI_API_KEY is not set."
    return 0
  fi
  local tmp_body http_status
  tmp_body="$(mktemp)"
  http_status="$(curl -sS --max-time 8 -o "$tmp_body" -w '%{http_code}' \
    -H "Authorization: Bearer ${key}" \
    "https://api.moonshot.cn/v1/users/me/balance" 2>/dev/null || true)"
  if [ "$http_status" != "200" ]; then
    local message
    message="$(jq -r '.error.message // .message // empty' "$tmp_body" 2>/dev/null || true)"
    [ -n "$message" ] || message="Kimi/Moonshot balance API returned HTTP ${http_status:-0}."
    rm -f "$tmp_body"
    json_error kimi kimi-api "${http_status:-1}" provider "$message"
    return 0
  fi
  jq -c '
    def num($v): ($v // 0 | tonumber? // 0);
    .data as $d
    | num($d.available_balance) as $avail
    | num($d.voucher_balance) as $voucher
    | num($d.cash_balance) as $cash
    | (if $avail <= 0 then 100 else 0 end) as $used_pct
    | {
        provider: "kimi",
        source: "kimi-api",
        usage: {
          identity: { providerID: "kimi", accountEmail: "Kimi account", loginMethod: "api-key" },
          accountEmail: "Kimi account",
          loginMethod: "api-key",
          primary: {
            usedPercent: $used_pct,
            windowMinutes: null,
            resetsAt: null,
            resetDescription: "Available balance (CNY)",
            displayValue: ("¥" + ($d.available_balance | tostring))
          },
          secondary: {
            usedPercent: 0,
            windowMinutes: null,
            resetsAt: null,
            resetDescription: "Voucher / Cash",
            displayValue: ("¥" + ($voucher | tostring) + " / ¥" + ($cash | tostring))
          },
          tertiary: null,
          updatedAt: (now | todateiso8601)
        },
        credits: {
          remaining: ("¥" + ($d.available_balance | tostring))
        }
      }
  ' "$tmp_body"
  rm -f "$tmp_body"
}

fetch_minimax_native() {
  local key="${MINIMAX_API_KEY:-}"
  if [ -z "$key" ]; then
    json_error minimax minimax-api 2 provider "MINIMAX_API_KEY is not set."
    return 0
  fi
  local tmp_body http_status
  tmp_body="$(mktemp)"
  http_status="$(curl -sS --max-time 8 -o "$tmp_body" -w '%{http_code}' \
    -H "Authorization: Bearer ${key}" \
    -H "Content-Type: application/json" \
    "https://www.minimax.io/v1/token_plan/remains" 2>/dev/null || true)"
  if [ "$http_status" != "200" ]; then
    local message
    message="$(jq -r '.base_resp.status_msg // .message // empty' "$tmp_body" 2>/dev/null || true)"
    [ -n "$message" ] || message="MiniMax token_plan/remains returned HTTP ${http_status:-0}."
    rm -f "$tmp_body"
    json_error minimax minimax-api "${http_status:-1}" provider "$message"
    return 0
  fi
  jq -c '
    def num($v): ($v // 0 | tonumber? // 0);
    . as $d
    | (num($d.remains // $d.remaining // 0)) as $remains
    | (num($d.total // 0)) as $total
    | (if $total > 0 then ((($total - $remains) / $total) * 100) | if . < 0 then 0 elif . > 100 then 100 else . end else 0 end) as $used_pct
    | {
        provider: "minimax",
        source: "minimax-api",
        usage: {
          identity: { providerID: "minimax", accountEmail: "MiniMax account", loginMethod: "api-key" },
          accountEmail: "MiniMax account",
          loginMethod: "api-key",
          primary: {
            usedPercent: $used_pct,
            windowMinutes: null,
            resetsAt: null,
            resetDescription: "Token plan remaining",
            displayValue: (($remains | tostring) + " tokens")
          },
          secondary: null,
          tertiary: null,
          updatedAt: (now | todateiso8601)
        },
        credits: { remaining: (($remains | tostring) + " tokens") }
      }
  ' "$tmp_body"
  rm -f "$tmp_body"
}

fetch_glm_native() {
  local key="${GLM_API_KEY:-${ZHIPU_API_KEY:-}}"
  if [ -z "$key" ]; then
    json_error glm glm-api 2 provider "GLM_API_KEY or ZHIPU_API_KEY is not set."
    return 0
  fi
  local base_url="https://bigmodel.cn"
  [ -n "${GLM_API_BASE:-}" ] && base_url="${GLM_API_BASE%/}"
  local tmp_body http_status
  tmp_body="$(mktemp)"
  http_status="$(curl -sS --max-time 8 -o "$tmp_body" -w '%{http_code}' \
    -H "Authorization: Bearer ${key}" \
    -H "Content-Type: application/json" \
    "${base_url}/api/monitor/usage/quota/limit" 2>/dev/null || true)"
  if [ "$http_status" != "200" ]; then
    local message
    message="$(jq -r '.message // .msg // empty' "$tmp_body" 2>/dev/null || true)"
    [ -n "$message" ] || message="GLM quota API returned HTTP ${http_status:-0}."
    rm -f "$tmp_body"
    json_error glm glm-api "${http_status:-1}" provider "$message"
    return 0
  fi
  jq -c '
    def num($v): ($v // 0 | tonumber? // 0);
    def pct($used; $total):
      if num($total) > 0 then ((num($used) / num($total)) * 100) | if . < 0 then 0 elif . > 100 then 100 else . end
      else 0 end;
    . as $d
    | (num($d.used // $d.usedTokens // 0)) as $used
    | (num($d.total // $d.totalTokens // 0)) as $total
    | ($d.resetTime // $d.reset_time // null) as $reset
    | {
        provider: "glm",
        source: "glm-api",
        usage: {
          identity: { providerID: "glm", accountEmail: ($d.accountId // "Zhipu account"), loginMethod: "api-key" },
          accountEmail: ($d.accountId // "Zhipu account"),
          loginMethod: "api-key",
          primary: {
            usedPercent: pct($used; $total),
            windowMinutes: (if ($d.windowHours // null) != null then (($d.windowHours // 5) * 60 | round) else null end),
            resetsAt: $reset,
            resetDescription: "Quota window",
            displayValue: (($used | tostring) + " / " + ($total | tostring) + " tokens")
          },
          secondary: null,
          tertiary: null,
          updatedAt: (now | todateiso8601)
        },
        credits: {
          remaining: ((num($total) - num($used) | tostring) + " tokens")
        }
      }
  ' "$tmp_body"
  rm -f "$tmp_body"
}

