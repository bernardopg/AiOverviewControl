fetch_xai_native() {
  local key="${XAI_API_KEY:-}"
  if [ -z "$key" ]; then
    json_error xai xai-api 2 provider "XAI_API_KEY is not set. Get your key at console.x.ai/team/default/api-keys"
    return 0
  fi
  local tmp_body http_status
  tmp_body="$(mktemp)"
  # GET /v1/api-key is the documented zero-cost key introspection endpoint. It
  # returns key metadata (name, acls, blocked/disabled flags) — no token spend,
  # unlike a chat/responses call. Falls back to /v1/models if the management
  # surface is unavailable for this key.
  http_status="$(curl -sS --max-time 8 -o "$tmp_body" -w '%{http_code}' \
    -H "Authorization: Bearer ${key}" \
    -H "Accept: application/json" \
    "https://api.x.ai/v1/api-key" 2>/dev/null || true)"
  if [ "$http_status" = "200" ]; then
    local name blocked note
    name="$(jq -r '.name // "xAI key"' "$tmp_body" 2>/dev/null || printf 'xAI key')"
    blocked="$(jq -r '.api_key_blocked // .team_blocked // .api_key_disabled // false' "$tmp_body" 2>/dev/null || printf 'false')"
    rm -f "$tmp_body"
    if [ "$blocked" = "true" ]; then
      json_error xai xai-api 3 provider "xAI API key \"${name}\" is blocked or disabled. Manage at console.x.ai/team/default/api-keys"
      return 0
    fi
    note="Authenticated as \"${name}\" — billing at console.x.ai/billing"
    json_note_usage xai xai-api "$name" "api-key" "$note" "console.x.ai/billing"
    return 0
  fi
  # xAI signals an invalid key as HTTP 400 with code "invalid-argument"
  # (not 401), plus 401/403 for auth/permission issues. All are key problems.
  case "$http_status" in 400|401|403)
    local message
    message="$(jq -r '.error // .message // empty' "$tmp_body" 2>/dev/null || true)"
    [ -n "$message" ] || message="xAI API key invalid (HTTP ${http_status})."
    rm -f "$tmp_body"
    json_error xai xai-api "${http_status}" provider "$message"
    return 0
  esac
  rm -f "$tmp_body"
  json_note_usage xai xai-api "xAI account" "api-key" "API key set; billing at console.x.ai/billing" "console.x.ai/billing"
}

