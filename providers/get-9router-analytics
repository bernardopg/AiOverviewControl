#!/usr/bin/env bash
set -euo pipefail

# Emit 9Router local telemetry as one JSON object for the dashboard card:
#   {
#     days:       [7 entries, oldest→today: {date, weekday, requests, cost, promptTokens, completionTokens}],
#     topModels:  [up to 6, 7-day window, sorted by cost desc: {model, provider, requests, cost, tokens}],
#     byProvider: [7-day window, sorted by cost desc: {provider, requests, cost}],
#     today / week / month: {requests, cost, promptTokens, completionTokens}
#   }
# Source of truth: ~/.9router/db/data.sqlite (usageDaily), fallback ~/.9router/usage.json.

db_path="${HOME}/.9router/db/data.sqlite"
usage_json="${HOME}/.9router/usage.json"
tmp_rows="$(mktemp)"
trap 'rm -f "$tmp_rows"' EXIT

if command -v sqlite3 >/dev/null 2>&1 && [ -f "$db_path" ]; then
  sqlite3 -json "$db_path" \
    "select dateKey as date, data from usageDaily where dateKey >= date('now','-35 days') order by dateKey" \
    >"$tmp_rows" 2>/dev/null || true
fi

if [ ! -s "$tmp_rows" ] && [ -f "$usage_json" ]; then
  jq -c '[.dailySummary // {} | to_entries[] | {date:.key,data:(.value|tojson)}]' \
    "$usage_json" >"$tmp_rows" 2>/dev/null || true
fi

if [ ! -s "$tmp_rows" ]; then
  echo '{"error":"9router usage database not found"}'
  exit 0
fi

jq -c --arg today "$(date +%F)" --arg month_prefix "$(date +%Y-%m)" '
  def num($v): ($v // 0 | tonumber? // 0);
  def zero: {requests:0, cost:0, promptTokens:0, completionTokens:0};
  def add_day($acc; $d):
    $acc
    | .requests += num($d.requests)
    | .cost += num($d.cost)
    | .promptTokens += num($d.promptTokens)
    | .completionTokens += num($d.completionTokens);

  [ .[] | {date, day:(.data | if type == "string" then fromjson else . end)} ] as $all
  | ($today | strptime("%Y-%m-%d") | mktime) as $today_epoch

  # Calendar-aligned last 7 days (missing days become zeros, so the chart
  # always shows a full week and weekday labels line up).
  | ([ range(6; -1; -1) as $offset
      | (($today_epoch - $offset * 86400) | strftime("%Y-%m-%d")) as $date
      | ($all | map(select(.date == $date)) | first | .day // {}) as $d
      | {
          date: $date,
          weekday: (($today_epoch - $offset * 86400) | strftime("%a")),
          requests: num($d.requests),
          cost: num($d.cost),
          promptTokens: num($d.promptTokens),
          completionTokens: num($d.completionTokens)
        }
    ]) as $days

  | ($all | map(select(.date == $today)) | first | .day // {}) as $today_day
  | ([ $days[] | {requests, cost, promptTokens, completionTokens} ]
      | reduce .[] as $d (zero; add_day(.; $d))) as $week
  | ($all | map(select(.date | startswith($month_prefix)) | .day)
      | reduce .[] as $d (zero; add_day(.; $d))) as $month

  # 7-day model and provider aggregation.
  | ([ $days[].date ]) as $week_dates
  | ($all | map(select(.date as $d | $week_dates | index($d)))) as $week_rows
  | ([ $week_rows[] | .day.byModel // {} | to_entries[] ]
      | group_by(.key)
      | map({
          key: .[0].key,
          model: (.[0].value.rawModel // (.[0].key | split("|")[0])),
          provider: (.[0].value.provider // (.[0].key | split("|")[1] // "")),
          requests: (map(num(.value.requests)) | add),
          cost: (map(num(.value.cost)) | add),
          tokens: (map(num(.value.promptTokens) + num(.value.completionTokens)) | add)
        })
      | sort_by(-.cost) | .[0:6]) as $top_models
  | ([ $week_rows[] | .day.byProvider // {} | to_entries[] ]
      | group_by(.key)
      | map({
          provider: .[0].key,
          requests: (map(num(.value.requests)) | add),
          cost: (map(num(.value.cost)) | add)
        })
      | sort_by(-.cost)) as $by_provider

  | {
      days: $days,
      topModels: $top_models,
      byProvider: $by_provider,
      today: {
        requests: num($today_day.requests),
        cost: num($today_day.cost),
        promptTokens: num($today_day.promptTokens),
        completionTokens: num($today_day.completionTokens)
      },
      week: $week,
      month: $month
    }
' "$tmp_rows"
